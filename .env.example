# ==============================================
# Gemini Web Cookies
# ==============================================
# 默认账号 (无后缀)
__Secure-1PSID=
__Secure-1PSIDTS=

# 额外账号 (自定义名称后缀)
# __Secure-1PSID_main=
# __Secure-1PSIDTS_main=

# ==============================================
# 负载均衡配置
# ==============================================
# 启用的账号列表，支持: [main,work] / {main,work} / main,work
# 留空则自动使用所有已配置的账号
ACCOUNTS=

# ==============================================
# HTTP 代理配置（可选）
# ==============================================
# 全局代理：所有账号默认使用
# 支持：http://host:port / http://user:pass@host:port / socks5://host:port
PROXY=

# 每账号独立代理：覆盖全局 PROXY
# 示例：PROXY_main=socks5://127.0.0.1:7890
# PROXY_main=

# ==============================================
# IP 协议族选择（可选）
# ==============================================
# 强制 dialer 只用 IPv4 或 IPv6 出口。
# 适用于"我的 IPv6 段被 Gemini 风控但 IPv4 正常"（或反过来）
# 这种场景，避免每次连接被系统选到坏的那一族。
#
# 取值（大小写不敏感，等价别名都接受）：
#   auto / 留空     - 默认，跟随操作系统（通常 IPv6 优先）
#   ipv4 / v4 / 4   - 只用 IPv4
#   ipv6 / v6 / 6   - 只用 IPv6
IP_FAMILY=

# 每账号独立 IP family：覆盖全局 IP_FAMILY
# 示例：IP_FAMILY_main=ipv4
# IP_FAMILY_main=

# ==============================================
# Cookie 自动刷新（可选）
# ==============================================
# __Secure-1PSIDTS 后台轮换间隔，单位秒。最小 60。
# 默认 600（10 分钟），跟上游 gemini-webapi 一致。
# COOKIE_REFRESH_INTERVAL_SECONDS=600

# ==============================================
# API 安全配置
# ==============================================
PROXY_API_KEY=

# ==============================================
# 服务端口
# ==============================================
PORT=8007

# ==============================================
# 語言配置
# ==============================================
# 用於 Accept-Language header 和 f.req payload 語言字段
# 默認: en，可選: zh-TW, zh-CN, ja, ko 等
LANGUAGE=en

# ==============================================
# 运行时行为
# ==============================================
# normal | temporary
CHAT_MODE=normal
MAX_CHARS=1000000
OVERSIZED_STRATEGY=compact
SESSION_TTL_MINUTES=15
WATCHDOG_TIMEOUT=300
SNAPSHOT_STREAMING=0

# ==============================================
# 存储
# ==============================================
STORAGE_PATH=./data/sessions.db
STORAGE_MAX_SIZE_MB=256
RETENTION_DAYS=14
CLEANUP_INTERVAL_HOURS=6

# ==============================================
# 模型映射 (Claude/OpenAI 模型名 -> Gemini 模型名)
# ==============================================
# 格式: source1:target1,source2:target2
MODEL_MAPPING=
